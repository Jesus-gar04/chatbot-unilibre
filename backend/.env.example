# ── DeepSeek LLM ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
LLM_MODEL=deepseek-chat        # deepseek-chat | deepseek-reasoner

# ── Credenciales del administrador ────────────────────────────────────────────
ADMIN_USERNAME=secretaria
ADMIN_PASSWORD=cambia_esta_contraseña

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=genera_con_openssl_rand_-hex_32
JWT_EXPIRE_MINUTES=480

# ── Supabase ───────────────────────────────────────────────────────────────────
# URL del proyecto (Settings > API > Project URL)
SUPABASE_URL=https://<project-ref>.supabase.co

# Clave service_role (Settings > API > Project API keys > service_role)
# NUNCA expongas esta clave en el frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Cadena de conexión directa a PostgreSQL
# (Settings > Database > Connection string > URI — usar "Session mode" / direct)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Nombre del bucket de Storage (créalo como privado en Supabase > Storage)
STORAGE_BUCKET=documents

# ── RAG ────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_K=5
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── CORS ───────────────────────────────────────────────────────────────────────
# Dev local → dejar los localhost (o no definir esta variable, usa el default)
# Render (producción) → solo la URL de Vercel
ALLOWED_ORIGINS=["https://chatbot-unilibre.vercel.app"]

# ── Producción ─────────────────────────────────────────────────────────────────
# Poner true en Render — desactiva /docs y /redoc públicamente
PRODUCTION=true
