# ── DeepSeek LLM ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
LLM_MODEL=deepseek-chat

# ── Admin (credenciales del secretario) ────────────────────────────────────────
ADMIN_USERNAME=secretaria
ADMIN_PASSWORD=contraseña_segura_aqui

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=genera_con_openssl_rand_-hex_32
JWT_EXPIRE_MINUTES=480

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres.[project-ref]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
STORAGE_BUCKET=documents

# ── Embeddings ─────────────────────────────────────────────────────────────────
# Obtener en https://dash.voyageai.com → API Keys (gratis, 50M tokens/mes)
VOYAGE_API_KEY=pa-...
USE_LOCAL_EMBEDDINGS=false

# ── RAG ────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_K=5

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Producción ─────────────────────────────────────────────────────────────────
PRODUCTION=true
