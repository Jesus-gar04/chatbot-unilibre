# ── DeepSeek LLM ───────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=
LLM_MODEL=gpt-4o

# ── Admin (credenciales del secretario) ────────────────────────────────────────
ADMIN_USERNAME=secretaria
ADMIN_PASSWORD=contraseña_segura_aqui

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=genera_con__openssl_rand_-hex_32
JWT_EXPIRE_MINUTES=480

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
STORAGE_BUCKET=

# ── RAG ────────────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_K=5
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
